{
  "name": "lobster-installer",
  "version": "0.8.0",
  "description": "Bostonclaw 安装器 - 企业 AI Agent Runtime 的一键接入向导",
  "main": "dist-electron/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamiltonmatthew308-ui/bostonclaw.git"
  },
  "author": "Bostonclaw",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "test": "vitest run",
    "package": "vite build",
    "package:win": "vite build && electron-builder --win --publish never",
    "package:mac": "vite build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@lobster/shared": "workspace:*",
    "electron-store": "^11.0.2",
    "https-proxy-agent": "^9.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "i18next": "^25.8.11",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@10.31.0"
}
